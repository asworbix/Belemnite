{
  "name": "belemnite",
  "version": "0.2.0",
  "description": "Bite back. A scraper-trapping middleware for any modern runtime.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./data/crawlers.json": "./dist/data/crawlers.json",
    "./data/verified-bots.json": "./dist/data/verified-bots.json",
    "./data/asns.json": "./dist/data/asns.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "refresh-bots": "node scripts/refresh-verified-bots.mjs",
    "prepare": "node scripts/build.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "next": "^14.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "next": ">=13"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "scraper",
    "ai",
    "middleware",
    "nextjs",
    "vercel",
    "honeypot",
    "markov",
    "bot-detection"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/asworbix/belemnite"
  }
}
